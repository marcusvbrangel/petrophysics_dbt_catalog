{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.11.8", "generated_at": "2026-05-02T21:19:45.375174Z", "invocation_id": "02bf5fdb-3d6f-474a-981e-c12a0e4992dc", "invocation_started_at": "2026-05-02T21:19:43.863568Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-02T21:19:45.007577Z", "completed_at": "2026-05-02T21:19:45.016916Z"}, {"name": "execute", "started_at": "2026-05-02T21:19:45.017529Z", "completed_at": "2026-05-02T21:19:45.017549Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.011349916458129883, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.petrophysics_catalog.stg_raw_logs", "compiled": true, "compiled_code": "select\n    cast(well_id as varchar) as well_id,\n    cast(md_m as double) as md_m,\n    cast(zone as varchar) as zone,\n    cast(gr_api as double) as gr_api,\n    cast(rhob_gcc as double) as rhob_gcc,\n    cast(nphi_vv as double) as nphi_vv,\n    cast(dt_usft as double) as dt_usft,\n    cast(dts_usft as double) as dts_usft,\n    cast(rt_ohmm as double) as rt_ohmm\nfrom raw_logs", "relation_name": "\"reservoir\".\"main\".\"stg_raw_logs\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-02T21:19:45.021234Z", "completed_at": "2026-05-02T21:19:45.030665Z"}, {"name": "execute", "started_at": "2026-05-02T21:19:45.033570Z", "completed_at": "2026-05-02T21:19:45.033597Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.013767480850219727, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.petrophysics_catalog.int_petrophysics", "compiled": true, "compiled_code": "with\nbase as (\n    select\n        well_id,\n        md_m,\n        zone,\n        gr_api,\n        rhob_gcc,\n        nphi_vv,\n        dt_usft,\n        dts_usft,\n        rt_ohmm,\n\n        304800.0 / nullif(dt_usft, 0) as vp_ms,\n        304800.0 / nullif(dts_usft, 0) as vs_ms,\n        rhob_gcc * 1000.0 as rho_kgm3,\n        nphi_vv as phi_nphi,\n        (gr_api - 30.0) / nullif((130.0 - 30.0), 0) as vsh_raw\n    from \"reservoir\".\"main\".\"stg_raw_logs\"\n),\nclean as (\n    select\n        *,\n        least(greatest(vsh_raw, 0.0), 1.0) as vsh,\n        least(greatest(phi_nphi, 0.01), 0.35) as phi\n    from base\n),\nelastic as (\n    select\n        *,\n        rho_kgm3 * vs_ms * vs_ms as shear_modulus_pa,\n        rho_kgm3 * (vp_ms * vp_ms - (4.0 / 3.0) * vs_ms * vs_ms) as bulk_modulus_pa,\n        vp_ms / nullif(vs_ms, 0) as vpvs_ratio\n    from clean\n),\nelastic2 as (\n    select\n        *,\n        9.0 * bulk_modulus_pa * shear_modulus_pa\n            / nullif(3.0 * bulk_modulus_pa + shear_modulus_pa, 0) as young_modulus_pa,\n        (3.0 * bulk_modulus_pa - 2.0 * shear_modulus_pa)\n            / nullif(2.0 * (3.0 * bulk_modulus_pa + shear_modulus_pa), 0) as poisson_ratio,\n        1.0 / nullif(bulk_modulus_pa, 0) as rock_compressibility_1pa,\n        rho_kgm3 * vp_ms as acoustic_impedance,\n        rho_kgm3 * vs_ms as shear_impedance\n    from elastic\n),\nfluid as (\n    select\n        *,\n        sqrt(((1.0 / power(phi, 2.0)) * 0.08) / nullif(rt_ohmm, 0)) as sw_raw,\n        1000.0 * power(phi, 4.0) / nullif(power(1.0 - phi, 2.0), 0) as perm_md_raw\n    from elastic2\n),\nfinal as (\n    select\n        *,\n        least(greatest(sw_raw, 0.0), 1.0) as sw,\n        1.0 - least(greatest(sw_raw, 0.0), 1.0) as so,\n        greatest(perm_md_raw, 0.001) as perm_md,\n        greatest(perm_md_raw, 0.001) * 9.869233e-16 as perm_m2,\n        1.0 - bulk_modulus_pa / 37.0e9 as biot_alpha_raw,\n        perm_md_raw * 9.869233e-16 /\n            nullif(phi * 0.001 * ((1.0 / nullif(bulk_modulus_pa, 0)) + 4.4e-10), 0)\n            as hydraulic_diffusivity_m2s\n    from fluid\n)\nselect\n    well_id,\n    md_m,\n    zone,\n    gr_api,\n    rhob_gcc,\n    nphi_vv,\n    dt_usft,\n    dts_usft,\n    rt_ohmm,\n    vp_ms,\n    vs_ms,\n    rho_kgm3,\n    phi,\n    vsh,\n    sw,\n    so,\n    perm_md,\n    perm_m2,\n    shear_modulus_pa,\n    bulk_modulus_pa,\n    young_modulus_pa,\n    poisson_ratio,\n    rock_compressibility_1pa,\n    acoustic_impedance,\n    shear_impedance,\n    vpvs_ratio,\n    least(greatest(biot_alpha_raw, 0.2), 1.0) as biot_alpha,\n    hydraulic_diffusivity_m2s\nfrom final", "relation_name": "\"reservoir\".\"main\".\"int_petrophysics\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-02T21:19:45.034636Z", "completed_at": "2026-05-02T21:19:45.076226Z"}, {"name": "execute", "started_at": "2026-05-02T21:19:45.078619Z", "completed_at": "2026-05-02T21:19:45.078652Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.050545692443847656, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.petrophysics_catalog.accepted_values_stg_raw_logs_zone__SEAL_TOP__RES_A__SEAL_MID__RES_B.9857731dd6", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        zone as value_field,\n        count(*) as n_records\n\n    from \"reservoir\".\"main\".\"stg_raw_logs\"\n    group by zone\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'SEAL_TOP','RES_A','SEAL_MID','RES_B'\n)\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-02T21:19:45.045062Z", "completed_at": "2026-05-02T21:19:45.080114Z"}, {"name": "execute", "started_at": "2026-05-02T21:19:45.082800Z", "completed_at": "2026-05-02T21:19:45.082816Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.05370950698852539, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.petrophysics_catalog.not_null_stg_raw_logs_md_m.a2792b212f", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect md_m\nfrom \"reservoir\".\"main\".\"stg_raw_logs\"\nwhere md_m is null\n\n\n", "relation_name": 